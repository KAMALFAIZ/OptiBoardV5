    // Filtre optionnel : si vide, tous les agents enregistrés sont démarrés
    "AgentFilter": ""
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
