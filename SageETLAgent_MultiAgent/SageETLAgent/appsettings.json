{
  "SageEtl": {
    // Mode connecté (master KASOFT)
    // "ServerUrl": "http://kasoft.selfip.net:50231",

    // Mode client autonome (standalone Docker)
    // Remplacer <IP_POSTE_CLIENT> par l'IP du poste où Docker tourne
    // Exemple : "ServerUrl": "http://192.168.1.50:8080"
    "ServerUrl": "http://localhost:8080",

    // Code client (doit correspondre à DWH_CODE dans le .env du standalone)
