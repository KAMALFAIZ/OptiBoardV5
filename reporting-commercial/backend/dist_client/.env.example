# ======================================================================
#  OptiBoard - Configuration
#  Modifiez les valeurs ci-dessous selon votre environnement puis
#  redemarrez le service OptiBoard-Backend (Services Windows ou stop_backend.bat)
# ======================================================================

# --- Base de donnees SQL Server ---
DB_HOST=localhost
DB_PORT=1433
DB_NAME=OptiBoard
DB_USER=sa
DB_PASSWORD=CHANGE_ME
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_ENCRYPT=yes
DB_TRUST_CERT=yes

# --- Serveur API ---
API_HOST=0.0.0.0
API_PORT=8084
DEBUG=False

# --- Securite ---
# IMPORTANT: generez une cle aleatoire unique par installation
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_64_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Licence OptiBoard ---
LICENSE_KEY=
LICENSE_SERVER_URL=https://license.kasoft.ma/api
LICENSE_SIGNING_SECRET=F36XJAyo4dHrXMtcDH_i17swtkTw2BxQVx78gPN9vxOyRVkXD7E0DG20roR7hqev

# --- Email SMTP (optionnel) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=optiboard@example.com
SMTP_TLS=True

# --- IA (optionnel) ---
AI_PROVIDER=anthropic
AI_API_KEY=
AI_MODEL=claude-sonnet-4

# --- CORS (domaines autorises) ---
CORS_ORIGINS=http://localhost:8084,http://localhost:3000
