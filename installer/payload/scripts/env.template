# ======================================================================
#  OptiBoard - Configuration
#  Modifiez les valeurs ci-dessous selon votre environnement puis
#  redemarrez le service OptiBoard-Backend (Services Windows ou stop_backend.bat)
# ======================================================================

# --- Base de donnees SQL Server (centrale / admin) ---
DB_SERVER=
DB_PORT=1433
DB_NAME=OptiBoard
DB_USER=
DB_PASSWORD=
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_ENCRYPT=no
DB_TRUST_CERT=yes
DB_CONNECT_TIMEOUT=3

# --- Serveur API ---
API_HOST=0.0.0.0
API_PORT=8084
DEBUG=False

# --- Securite ---
# IMPORTANT: generez une cle aleatoire unique par installation
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_64_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=1440

