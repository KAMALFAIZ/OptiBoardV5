# ============================================================
# OptiBoard v5 — Variables d'environnement Production
# Copier ce fichier en .env sur le serveur et remplir les valeurs
# NE JAMAIS committer le fichier .env avec de vraies valeurs !
# ============================================================

# ── GitHub ───────────────────────────────────────────────
GITHUB_OWNER=kamalfaiz

# ── Base de données SQL Server ────────────────────────────
DB_SERVER=IP_DU_SERVEUR_SQL ou nom_du_service
DB_NAME=GROUPE_ALBOUGHAZE
DB_USER=sa
DB_PASSWORD=MOT_DE_PASSE_FORT_ICI

# ── Application ──────────────────────────────────────────
SECRET_KEY=CHAINE_ALEATOIRE_TRES_LONGUE_64_CHARS
DEBUG=False
CACHE_TTL=300
MAX_ROWS=10000
QUERY_TIMEOUT=30

# ── CORS (domaine(s) autorisé(s)) ────────────────────────
ALLOWED_ORIGINS=https://votre-domaine.com

# ── Email (si notifications activées) ───────────────────
MAIL_SERVER=smtp.exemple.com
MAIL_PORT=587
MAIL_USERNAME=email@exemple.com
MAIL_PASSWORD=MOT_DE_PASSE_EMAIL
MAIL_FROM=optiboard@exemple.com

# ── License Server ───────────────────────────────────────
LICENSE_SERVER_URL=http://license-server:8001
